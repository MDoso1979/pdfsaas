rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users collection
    match /users/{userId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
    }

    // Usage collection
    match /usage/{usageId} {
      // Allow read and write for both authenticated users and anonymous sessions (which use standard sess_ prefix)
      allow read, write: if true;
    }

    // History collection
    match /history/{historyId} {
      allow read: if (request.auth != null && resource.data.uid == request.auth.uid) || isAdmin();
      allow write: if (request.auth != null && request.resource.data.uid == request.auth.uid) || isAdmin();
    }

    // Feedback collection
    match /feedback/{feedbackId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }

    // Transactions collection
    match /transactions/{transactionId} {
      allow read: if (request.auth != null && resource.data.uid == request.auth.uid) || isAdmin();
      allow write: if (request.auth != null && request.resource.data.uid == request.auth.uid) || isAdmin();
    }
  }
}
